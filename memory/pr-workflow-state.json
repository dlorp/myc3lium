  "notes": [
    "This file enforces AXIOM-001 (wait for CI) and AXIOM-002 (security review mandatory)",
    "State can only transition via valid paths defined in transitions object",
    "READY state is terminal - PR must pass all prior gates",
    "CI_RUNNING can loop back to FIXES_APPLIED if CI fails",
    "Never announce PR ready unless state === READY"
  ],
  "validation_status_values": [
    "not_started - validation not started",
    "running - agent spawned, waiting for completion",
    "completed - agent finished, file exists",
    "validated - file reviewed, result recorded (pass/fail)"
  ],
  "integration_notes": [
    "Security review uses TWO-LAYER validation:",
    "  1. Static analysis (openclaw-dash audit): deps, secrets, patterns",
    "  2. LLM agent (@security-specialist): context-aware code review",
    "Static analysis runs FIRST (blocks if critical_issues > 0)",
    "LLM agent only spawns if static analysis passes",
    "Both must pass for security_review.result === 'pass'",
    "openclaw-dash integration: audit (static), pr-auto (checks workflow state before merge)"
  ]
