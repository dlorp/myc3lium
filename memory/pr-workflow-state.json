{
  "$schema": "pr-workflow-state-v1",
  "version": "1.1.0",
  "description": "PR workflow state machine - tracks progress through mandatory review steps",
  "states": {
    "CREATED": "PR created, posted to #pull-requests",
    "SECURITY_REVIEW": "Security review in progress (static + LLM)",
    "CODE_REVIEW": "Code review in progress (@code-reviewer)",
    "FIXES_APPLIED": "All review fixes committed and pushed",
    "CI_RUNNING": "CI checks running (waiting for pass)",
    "READY": "All gates passed - PR ready for merge"
  },
  "transitions": {
    "CREATED": [
      "SECURITY_REVIEW"
    ],
    "SECURITY_REVIEW": [
      "CODE_REVIEW",
      "FIXES_APPLIED"
    ],
    "CODE_REVIEW": [
      "FIXES_APPLIED"
    ],
    "FIXES_APPLIED": [
      "CI_RUNNING"
    ],
    "CI_RUNNING": [
      "READY",
      "FIXES_APPLIED"
    ],
    "READY": []
  },
