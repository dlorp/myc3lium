#!/usr/bin/env bash
# myc3lium-netctl — Privileged network control helper
#
# Called by the myc3lium backend (running as non-root) to perform
# system-level network operations that require root privileges.
#
# Install: sudo cp myc3lium-netctl /usr/local/bin/ && sudo chmod 755 /usr/local/bin/myc3lium-netctl
# Sudoers: myc3 ALL=(ALL) NOPASSWD: /usr/local/bin/myc3lium-netctl
#
# Usage:
#   myc3lium-netctl write-hostapd <content>
#   myc3lium-netctl write-dnsmasq <content>
#   myc3lium-netctl write-wpa <content>
#   myc3lium-netctl start-ap
#   myc3lium-netctl stop-ap
#   myc3lium-netctl start-client <interface>
#   myc3lium-netctl stop-client <interface>
#   myc3lium-netctl setup-bridge
#   myc3lium-netctl teardown-bridge
#   myc3lium-netctl setup-nat <interface>
#   myc3lium-netctl remove-nat <interface>
#   myc3lium-netctl set-ip <interface> <ip/mask>
#   myc3lium-netctl flush-ip <interface>
#   myc3lium-netctl iface-up <interface>
#   myc3lium-netctl iface-down <interface>
#   myc3lium-netctl cleanup <interface>
#   myc3lium-netctl sysctl-forward

set -euo pipefail

HOSTAPD_CONF="/etc/hostapd/hostapd.conf"
DNSMASQ_CONF="/etc/dnsmasq.d/myc3lium-ap.conf"
WPA_CONF="/etc/wpa_supplicant/wpa_supplicant-backhaul.conf"
BRIDGE="br0"

# Validate interface name (wlanN, br0, eth0, bat0)
validate_iface() {
    if ! echo "$1" | grep -qE '^(wlan[0-9]{1,2}|br0|eth[0-9]|bat0)$'; then
        echo "ERROR: Invalid interface: $1" >&2
        exit 1
    fi
}

# Reset a USB WiFi adapter by unbinding/rebinding the USB device.
# Fixes rtw_8822bu driver stuck in bad state after mode switches.
reset_usb_adapter() {
    local IFACE="$1"
    local DEV_PATH
    DEV_PATH=$(readlink -f "/sys/class/net/${IFACE}/device" 2>/dev/null) || return 0

    # Only reset USB-backed adapters
    echo "$DEV_PATH" | grep -q "/usb" || return 0

    local USB_ID
    USB_ID=$(basename "$(dirname "$DEV_PATH")")
    if [ -n "$USB_ID" ] && [ -e "/sys/bus/usb/drivers/usb/${USB_ID}" ]; then
        echo "$USB_ID" > /sys/bus/usb/drivers/usb/unbind 2>/dev/null || true
        sleep 2
        echo "$USB_ID" > /sys/bus/usb/drivers/usb/bind 2>/dev/null || true
        sleep 2
    fi
}

# Ensure NetworkManager is not managing wlan0+bat0 for mesh use
ensure_nm_unmanaged_mesh() {
    local NM_CONF="/etc/NetworkManager/conf.d/99-myc3lium-mesh.conf"
    local EXPECTED
    EXPECTED=$(printf '[keyfile]\nunmanaged-devices=interface-name:wlan0;interface-name:bat0\n')
    # Always reconcile content, not just existence
    if [ -f "$NM_CONF" ] && [ "$(cat "$NM_CONF")" = "$EXPECTED" ]; then
        return 0
    fi
    mkdir -p "$(dirname "$NM_CONF")"
    printf '%s\n' "$EXPECTED" > "$NM_CONF"
    systemctl reload NetworkManager 2>/dev/null || true
    sleep 1
}

# Ensure NetworkManager is not managing the backhaul interface
ensure_nm_unmanaged() {
    local IFACE="$1"
    validate_iface "$IFACE"
    local NM_CONF="/etc/NetworkManager/conf.d/99-myc3lium-backhaul.conf"
    # Anchored match to avoid wlan1 matching wlan10
    if grep -qE "(^|;)interface-name:${IFACE}($|;|$)" "$NM_CONF" 2>/dev/null; then
        return 0
    fi
    mkdir -p "$(dirname "$NM_CONF")"
    # Append to existing unmanaged list, or create new
    if grep -q "^unmanaged-devices=" "$NM_CONF" 2>/dev/null; then
        sed -i "s/^unmanaged-devices=.*/&;interface-name:${IFACE}/" "$NM_CONF"
    else
        printf '[keyfile]\nunmanaged-devices=interface-name:%s\n' "$IFACE" > "$NM_CONF"
    fi
    systemctl reload NetworkManager 2>/dev/null || true
    sleep 1
}

case "${1:-}" in
    write-hostapd)
        # Read content from stdin
        mkdir -p "$(dirname "$HOSTAPD_CONF")"
        cat > "$HOSTAPD_CONF"
        chmod 600 "$HOSTAPD_CONF"
        ;;

    write-dnsmasq)
        mkdir -p "$(dirname "$DNSMASQ_CONF")"
        cat > "$DNSMASQ_CONF"
        chmod 644 "$DNSMASQ_CONF"
        ;;

    write-wpa)
        mkdir -p "$(dirname "$WPA_CONF")"
        cat > "$WPA_CONF"
        chmod 600 "$WPA_CONF"
        ;;

    start-ap)
        # Extract interface from hostapd.conf and validate
        AP_IFACE=$(grep '^interface=' "$HOSTAPD_CONF" 2>/dev/null | cut -d= -f2 || echo "wlan1")
        validate_iface "$AP_IFACE"
        ensure_nm_unmanaged "$AP_IFACE"

        # Reset USB adapter if hostapd fails on first attempt
        systemctl stop hostapd 2>/dev/null || true
        ip link set "$AP_IFACE" down 2>/dev/null || true
        sleep 1

        systemctl start hostapd 2>&1 || {
            # Driver stuck — USB reset and retry
            echo "hostapd failed, resetting USB adapter..."
            reset_usb_adapter "$AP_IFACE"
            # NM re-grabs after USB reset
            ensure_nm_unmanaged "$AP_IFACE"
            sleep 1
            systemctl reset-failed hostapd 2>/dev/null || true
            systemctl start hostapd
        }
        systemctl restart dnsmasq
        ;;

    stop-ap)
        systemctl stop hostapd 2>/dev/null || true
        systemctl stop dnsmasq 2>/dev/null || true
        ;;

    start-client)
        validate_iface "${2:?interface required}"
        IFACE="$2"
        ensure_nm_unmanaged "$IFACE"
        pkill -f "wpa_supplicant.*${IFACE}" 2>/dev/null || true
        pkill -f "dhclient.*${IFACE}" 2>/dev/null || true
        ip link set "$IFACE" down 2>/dev/null || true
        sleep 1
        ip link set "$IFACE" up
        wpa_supplicant -B -i "$IFACE" -c "$WPA_CONF" || {
            echo "wpa_supplicant failed, resetting USB adapter..."
            reset_usb_adapter "$IFACE"
            # NM re-grabs after USB reset — exclude again
            ensure_nm_unmanaged "$IFACE"
            sleep 1
            ip link set "$IFACE" up 2>/dev/null || true
            wpa_supplicant -B -i "$IFACE" -c "$WPA_CONF"
        }
        # Wait for association before requesting DHCP
        sleep 5
        dhclient "$IFACE"
        ;;

    stop-client)
        validate_iface "${2:?interface required}"
        IFACE="$2"
        pkill -f "wpa_supplicant.*${IFACE}" 2>/dev/null || true
        pkill -f "dhclient.*${IFACE}" 2>/dev/null || true
        ip addr flush dev "$IFACE" 2>/dev/null || true
        ip link set "$IFACE" down 2>/dev/null || true
        ;;

    setup-bridge)
        # Create br0 and add bat0
        ip link show "$BRIDGE" > /dev/null 2>&1 || ip link add name "$BRIDGE" type bridge
        ip link set bat0 master "$BRIDGE" 2>/dev/null || true
        ip link set "$BRIDGE" up
        ;;

    teardown-bridge)
        ip link set "$BRIDGE" down 2>/dev/null || true
        ip link delete "$BRIDGE" type bridge 2>/dev/null || true
        ;;

    setup-nat)
        validate_iface "${2:?interface required}"
        IFACE="$2"
        sysctl -w net.ipv4.ip_forward=1 > /dev/null

        # Determine NAT source (br0 if exists, else bat0)
        if ip link show "$BRIDGE" > /dev/null 2>&1; then
            SRC="$BRIDGE"
        else
            SRC="bat0"
        fi

        # Idempotent: check before add
        iptables -t nat -C POSTROUTING -o "$IFACE" -j MASQUERADE 2>/dev/null || \
            iptables -t nat -A POSTROUTING -o "$IFACE" -j MASQUERADE
        iptables -C FORWARD -i "$SRC" -o "$IFACE" -j ACCEPT 2>/dev/null || \
            iptables -A FORWARD -i "$SRC" -o "$IFACE" -j ACCEPT
        iptables -C FORWARD -i "$IFACE" -o "$SRC" -m state --state RELATED,ESTABLISHED -j ACCEPT 2>/dev/null || \
            iptables -A FORWARD -i "$IFACE" -o "$SRC" -m state --state RELATED,ESTABLISHED -j ACCEPT

        netfilter-persistent save 2>/dev/null || true
        ;;

    remove-nat)
        validate_iface "${2:?interface required}"
        IFACE="$2"
        for SRC in "$BRIDGE" bat0; do
            iptables -t nat -D POSTROUTING -o "$IFACE" -j MASQUERADE 2>/dev/null || true
            iptables -D FORWARD -i "$SRC" -o "$IFACE" -j ACCEPT 2>/dev/null || true
            iptables -D FORWARD -i "$IFACE" -o "$SRC" -m state --state RELATED,ESTABLISHED -j ACCEPT 2>/dev/null || true
        done
        netfilter-persistent save 2>/dev/null || true
        ;;

    set-ip)
        validate_iface "${2:?interface required}"
        ip addr flush dev "$2" 2>/dev/null || true
        ip addr add "${3:?ip/mask required}" dev "$2"
        ;;

    flush-ip)
        validate_iface "${2:?interface required}"
        ip addr flush dev "$2" 2>/dev/null || true
        ;;

    iface-up)
        validate_iface "${2:?interface required}"
        ip link set "$2" up
        ;;

    iface-down)
        validate_iface "${2:?interface required}"
        ip link set "$2" down 2>/dev/null || true
        ;;

    cleanup)
        # Full cleanup: stop all services, remove configs, teardown bridge/NAT
        systemctl stop hostapd 2>/dev/null || true
        systemctl stop dnsmasq 2>/dev/null || true

        if [ -n "${2:-}" ]; then
            validate_iface "$2"
            pkill -f "wpa_supplicant.*$2" 2>/dev/null || true
            ip addr flush dev "$2" 2>/dev/null || true
            ip link set "$2" down 2>/dev/null || true
            # Remove NAT
            for SRC in "$BRIDGE" bat0; do
                iptables -t nat -D POSTROUTING -o "$2" -j MASQUERADE 2>/dev/null || true
                iptables -D FORWARD -i "$SRC" -o "$2" -j ACCEPT 2>/dev/null || true
                iptables -D FORWARD -i "$2" -o "$SRC" -m state --state RELATED,ESTABLISHED -j ACCEPT 2>/dev/null || true
            done
        else
            # No interface known — kill any backhaul wpa_supplicant
            pkill -f "wpa_supplicant.*backhaul" 2>/dev/null || true
        fi

        # Teardown mesh (same logic as mesh-down)
        ip addr flush dev bat0 2>/dev/null || true
        ip link set bat0 down 2>/dev/null || true
        batctl meshif bat0 interface del wlan0 2>/dev/null || true
        iw dev wlan0 ibss leave 2>/dev/null || true
        ip link set wlan0 down 2>/dev/null || true
        iw dev wlan0 set type managed 2>/dev/null || true

        # Teardown bridge
        ip link set "$BRIDGE" down 2>/dev/null || true
        ip link delete "$BRIDGE" type bridge 2>/dev/null || true

        netfilter-persistent save 2>/dev/null || true

        # Remove config files and captive portal flag
        rm -f "$HOSTAPD_CONF" "$DNSMASQ_CONF" "$WPA_CONF"
        rm -f /opt/myc3lium/run/captive-portal
        ;;

    sysctl-forward)
        sysctl -w net.ipv4.ip_forward=1 > /dev/null
        ;;

    mesh-up)
        # Usage: mesh-up <ssid> <freq_mhz> <ip/mask>
        SSID="${2:?ssid required}"
        FREQ="${3:?frequency required}"
        MESH_IP="${4:?mesh ip/mask required}"

        # Validate SSID (alphanumeric, hyphens, underscores, max 32)
        if ! printf '%s\n' "$SSID" | grep -qE '^[A-Za-z0-9_-]{1,32}$'; then
            echo "ERROR: Invalid SSID: $SSID" >&2
            exit 1
        fi
        # Validate frequency (WiFi 2.4GHz: 2412-2484, 5GHz: 5180-5825)
        if ! printf '%s\n' "$FREQ" | grep -qE '^(24[0-9]{2}|5[0-8][0-9]{2})$'; then
            echo "ERROR: Invalid frequency: $FREQ" >&2
            exit 1
        fi
        # Validate IP/CIDR (strict: octets 0-255, mask 1-32)
        if ! printf '%s\n' "$MESH_IP" | grep -qE '^((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)/(3[0-2]|[12]?[0-9])$'; then
            echo "ERROR: Invalid IP/CIDR: $MESH_IP" >&2
            exit 1
        fi

        # Run setup in subshell so set -e catches any failure and we can rollback
        (
            set -euo pipefail

            # 1. Load kernel module
            modprobe batman-adv

            # 2. Unmanage wlan0 from NetworkManager
            ensure_nm_unmanaged_mesh

            # 3. Tear down existing mesh state (idempotent)
            ip link set bat0 down 2>/dev/null || true
            batctl meshif bat0 interface del wlan0 2>/dev/null || true
            iw dev wlan0 ibss leave 2>/dev/null || true
            ip link set wlan0 down 2>/dev/null || true

            # 4. Kill wpa_supplicant on wlan0 — NM unmanage alone may not stop it
            pkill -f "wpa_supplicant.*wlan0" 2>/dev/null || true

            # 5. Set IBSS mode and MTU (sleep for brcmfmac firmware disassociation)
            sleep 1
            iw dev wlan0 set type ibss
            ip link set wlan0 mtu 1532 2>/dev/null || true  # brcmfmac caps at 1500
            ip link set wlan0 up

            # 6. Join IBSS cell (no HT20 — brcmfmac has channel width bugs in IBSS)
            iw dev wlan0 ibss join "$SSID" "$FREQ"

            # 7. Verify IBSS join (brcmfmac can silently fail)
            sleep 1
            if ! iw dev wlan0 info 2>/dev/null | grep -qi "ibss"; then
                echo "ERROR: wlan0 did not enter IBSS mode after join" >&2
                exit 1
            fi

            # 8. Create bat0 and add wlan0
            batctl meshif bat0 interface create 2>/dev/null || true
            batctl meshif bat0 interface add wlan0

            # 9. Bring up bat0, assign IP
            ip link set bat0 up
            # bat0 MTU = wlan0 MTU minus 32B batman header
            # brcmfmac caps wlan0 at 1500, so bat0 max is 1468
            WLAN_MTU=$(cat /sys/class/net/wlan0/mtu 2>/dev/null || echo 1500)
            BAT_MTU=$((WLAN_MTU - 32))
            ip link set bat0 mtu "$BAT_MTU"
            ip addr flush dev bat0 2>/dev/null || true
            ip addr add "$MESH_IP" dev bat0

            # 10. Set batman parameters
            batctl meshif bat0 hop_penalty 15
            batctl meshif bat0 orig_interval 5000

            echo "OK: mesh-up ssid=$SSID freq=$FREQ ip=$MESH_IP"
        ) || {
            echo "ERROR: mesh-up failed, rolling back" >&2
            ip link set bat0 down 2>/dev/null || true
            batctl meshif bat0 interface del wlan0 2>/dev/null || true
            iw dev wlan0 ibss leave 2>/dev/null || true
            ip link set wlan0 down 2>/dev/null || true
            exit 1
        }
        ;;

    mesh-down)
        ip addr flush dev bat0 2>/dev/null || true
        ip link set bat0 down 2>/dev/null || true
        batctl meshif bat0 interface del wlan0 2>/dev/null || true
        iw dev wlan0 ibss leave 2>/dev/null || true
        ip link set wlan0 down 2>/dev/null || true
        # Restore managed mode so wlan0 is usable for other purposes
        iw dev wlan0 set type managed 2>/dev/null || true
        echo "OK: mesh-down"
        ;;

    mesh-status)
        if ip link show bat0 > /dev/null 2>&1; then
            BAT_STATE=$(cat /sys/class/net/bat0/operstate 2>/dev/null || echo "unknown")
            BAT_IP=$(ip -4 addr show bat0 2>/dev/null | grep -oP 'inet \K[0-9.]+' || echo "none")
            WLAN_TYPE=$(iw dev wlan0 info 2>/dev/null | grep -i "type" | awk '{print $2}' || echo "unknown")
            echo "bat0=$BAT_STATE ip=$BAT_IP wlan0_type=$WLAN_TYPE"
        else
            echo "bat0=absent"
        fi
        ;;

    set-captive-portal)
        mkdir -p /opt/myc3lium/run
        touch /opt/myc3lium/run/captive-portal
        chown myc3:myc3 /opt/myc3lium/run/captive-portal 2>/dev/null || true
        ;;

    clear-captive-portal)
        rm -f /opt/myc3lium/run/captive-portal
        ;;

    restart-dnsmasq)
        systemctl restart dnsmasq
        ;;

    *)
        echo "Usage: myc3lium-netctl <command> [args...]" >&2
        echo "Commands: write-hostapd write-dnsmasq write-wpa start-ap stop-ap" >&2
        echo "          start-client stop-client setup-bridge teardown-bridge" >&2
        echo "          setup-nat remove-nat set-ip flush-ip iface-up iface-down" >&2
        echo "          mesh-up mesh-down mesh-status" >&2
        echo "          cleanup sysctl-forward set-captive-portal" >&2
        echo "          clear-captive-portal restart-dnsmasq" >&2
        exit 1
        ;;
esac
