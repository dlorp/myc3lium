# MYC3LIUM Environment Configuration
# Copy this file to .env and update with your values

# Backend Configuration
DEBUG=true
API_PREFIX=/api
CORS_ORIGINS=http://localhost:3000

# Database (when implemented)
# DATABASE_URL=postgresql://user:password@localhost:5432/myc3lium

# Reticulum/HYPHA Integration (when implemented)
# HYPHA_SERVER_URL=https://hypha.aicell.io
# HYPHA_TOKEN=your-token-here

# Security (generate secure random strings in production)
# SECRET_KEY=your-secret-key-here
# JWT_SECRET=your-jwt-secret-here

# Frontend Configuration (if needed)
# VITE_API_URL=http://localhost:8000
